# Database connection.
# Dev default: local SQLite. For production/HIPAA use PostgreSQL with encryption
# at rest, e.g. postgresql://user:pass@host:5432/nextus?sslmode=require
# (and change `provider` in prisma/schema.prisma to "postgresql").
DATABASE_URL="file:./dev.db"

# Secret used to sign session tokens (JWT). Generate with:
#   openssl rand -base64 48
AUTH_SECRET="dev-only-secret-change-me-in-production"

# Idle session timeout in minutes (HIPAA guidance: keep short)
SESSION_IDLE_MINUTES="30"
